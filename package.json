{
  "name": "rss-translator",
  "version": "0.1.0",
  "packageManager": "pnpm@10.26.1",
  "description": "RSS 订阅翻译代理 — Cloudflare Worker",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "cf:typegen": "wrangler types",
    "push-config": "node scripts/push-config.mjs",
    "push-config:local": "node scripts/push-config.mjs --local",
    "cron-vps": "node --experimental-strip-types cron-vps.ts",
    "build:cron": "vite build --config vite.config.cron.ts",
    "build": "vite build --config vite.config.cron.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240401.0",
    "@eslint/js": "^9.23.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.23.0",
    "globals": "^17.4.0",
    "js-yaml": "^5.2.1",
    "typescript": "^5.3.3",
    "vite": "^8.1.3",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^3.12.0"
  }
}
