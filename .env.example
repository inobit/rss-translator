# ============================================================
# VPS 定时任务环境变量（复制为 .env，不要提交到仓库）
# ============================================================

# -- Cloudflare KV（读写缓存用）--
CF_ACCOUNT_ID=

# CF_KV_API_TOKEN 需到 Cloudflare Dashboard 创建自定义 Token：
#   右上角头像 → My Profile → API Tokens → Create Token → Custom
#   权限：Workers KV Storage → Edit
#   命名空间：指定 RSS_CACHE + RSS_CONFIG 两个 namespace
CF_KV_API_TOKEN=

CF_KV_CONFIG_ID=
CF_KV_CACHE_ID=

# -- 翻译 API Key（key 名必须与 wrangler secrets 一致）--
DEEPSEEK_API_KEY=

# 如有其他 provider，按需添加：
# CLOUDFLARE_API_KEY=
# DEEPLX_API_KEY=

# -- 可选 --
LOG_LEVEL=info
